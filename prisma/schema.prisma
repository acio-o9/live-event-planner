generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  sub       String    @unique
  slackSub  String?   @unique
  nickname  String
  avatarUrl String?
  role      String    @default("user")
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  createdEvents        LiveEvent[]
  createdEventBands    EventBand[]
  eventBandMemberships EventBandMember[]
  assignedTasks        Task[]            @relation("AssignedTasks")
  paidExpenses         Expense[]
  createdSchedules     BandSchedule[]
  instruments          UserInstrument[]
}

model Instrument {
  id    String           @id @default(uuid())
  name  String           @unique
  order Int              @default(0)
  users UserInstrument[]
}

model UserInstrument {
  userId       String
  instrumentId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@id([userId, instrumentId])
}

model LiveEvent {
  id            String    @id @default(uuid())
  title         String
  description   String?
  date          DateTime?
  venue         String?
  photoAlbumUrl String?
  status        String    @default("planning")
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator    User         @relation(fields: [createdBy], references: [id], onUpdate: Cascade)
  bands      EventBand[]
  milestones Milestone[]
  expenses   Expense[]
}

model EventBand {
  id          String   @id @default(uuid())
  liveEventId String
  name        String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  liveEvent       LiveEvent         @relation(fields: [liveEventId], references: [id], onDelete: Cascade)
  creator         User              @relation(fields: [createdBy], references: [id], onUpdate: Cascade)
  members         EventBandMember[]
  snapshots       MemberSnapshot[]
  setlist         Setlist?
  tasks           Task[]
  schedules       BandSchedule[]
}

model EventBandMember {
  eventBandId String
  userId      String
  role        String   @default("member")
  joinedAt    DateTime @default(now())

  eventBand EventBand @relation(fields: [eventBandId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onUpdate: Cascade)

  @@id([eventBandId, userId])
}

model BandSchedule {
  id          String   @id @default(uuid())
  eventBandId String
  location    String
  startAt     DateTime
  endAt       DateTime
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventBand EventBand @relation(fields: [eventBandId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [createdBy], references: [id], onUpdate: Cascade)
}

model MemberSnapshot {
  id          String   @id @default(uuid())
  eventBandId String
  userId      String
  nickname    String
  role        String
  takenAt     DateTime @default(now())

  eventBand EventBand @relation(fields: [eventBandId], references: [id], onDelete: Cascade)
}

model Milestone {
  id          String    @id @default(uuid())
  liveEventId String
  title       String
  dueDate     DateTime?
  status      String    @default("pending")
  order       Int
  createdAt   DateTime  @default(now())

  liveEvent LiveEvent @relation(fields: [liveEventId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id              String   @id @default(uuid())
  milestoneId     String
  eventBandId     String?
  title           String
  assigneeUserId  String?
  status          String   @default("pending")
  order           Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  milestone   Milestone  @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  eventBand   EventBand? @relation(fields: [eventBandId], references: [id], onDelete: SetNull)
  assignee    User?      @relation("AssignedTasks", fields: [assigneeUserId], references: [id], onUpdate: Cascade)
}

model Setlist {
  id          String   @id @default(uuid())
  eventBandId String   @unique
  updatedAt   DateTime @updatedAt

  eventBand EventBand   @relation(fields: [eventBandId], references: [id], onDelete: Cascade)
  songs     SetlistSong[]
}

model SetlistSong {
  id        String  @id @default(uuid())
  setlistId String
  title     String
  duration  Int?
  order     Int
  note      String?

  setlist Setlist @relation(fields: [setlistId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(uuid())
  liveEventId String
  paidBy      String
  amount      Int
  category    String   @default("その他")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  liveEvent  LiveEvent @relation(fields: [liveEventId], references: [id], onDelete: Cascade)
  paidByUser User      @relation(fields: [paidBy], references: [id], onUpdate: Cascade)
}
