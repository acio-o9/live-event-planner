FROM node:20-alpine

RUN apk add --no-cache libc6-compat openssl

WORKDIR /app

# Install dependencies (Linux binaries here)
COPY package.json package-lock.json ./
RUN npm ci

# Generate Prisma client with Linux binary
COPY prisma ./prisma
RUN npx prisma generate

EXPOSE 3000
ENV PORT=3000

CMD ["npm", "run", "dev"]
