# Google OAuth (Google Cloud Console で取得)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth (openssl rand -base64 32 で生成)
AUTH_SECRET=your-auth-secret
NEXTAUTH_URL=http://localhost:3000

# Database (ローカル開発: docker-compose の postgres を使う場合)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/live_event_planner

# Slack (本番環境のみ必須: users:read.email スコープが必要)
# ローカル環境では未設定でOK（検証スキップ）
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
